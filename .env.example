# LLM provider: mock (default, no API key) | openai
LLM_PROVIDER=mock

# Required when LLM_PROVIDER=openai (server-side only — never use NEXT_PUBLIC_)
# OPENAI_API_KEY=sk-...

# Cost-effective default for JSON agent outputs
OPENAI_MODEL=gpt-4o-mini

# Optional: proxy or Azure-style OpenAI-compatible host
# OPENAI_BASE_URL=https://api.openai.com/v1
